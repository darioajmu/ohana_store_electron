{
  "name": "ohana-store-desktop",
  "version": "0.1.0",
  "description": "Desktop shell for the Ohana Store application.",
  "author": "Ohana Store",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "frontend:dev": "yarn --cwd frontend dev",
    "frontend:dev:desktop": "yarn --cwd frontend dev:desktop",
    "frontend:build:desktop": "yarn --cwd frontend build:desktop",
    "desktop:prepare-runtime": "bash scripts/desktop/prepare_ruby_runtime.sh",
    "desktop:dev": "electron .",
    "desktop:build": "yarn frontend:build:desktop && yarn desktop:prepare-runtime",
    "desktop:dist": "yarn desktop:build && electron-builder --config electron-builder.config.js",
    "desktop:dist:dir": "yarn desktop:build && electron-builder --dir --config electron-builder.config.js"
  },
  "dependencies": {
    "@nextui-org/image": "^2.0.24",
    "@nextui-org/react": "^2.2.9",
    "@nextui-org/system": "^2.0.15",
    "@nextui-org/theme": "^2.1.17",
    "autoprefixer": "^10.4.17",
    "framer-motion": "^11.0.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^35.1.5",
    "electron-builder": "^24.13.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
